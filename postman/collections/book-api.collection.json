{
  "info": {
    "name": "Book API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "bookId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567801",
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "header": []
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has status ok', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ok');",
                  "    pm.expect(json.timestamp).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567802",
          "name": "List All Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"]
            },
            "header": []
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains books array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.books).to.be.an('array');",
                  "    pm.expect(json.books.length).to.be.at.least(1);",
                  "});",
                  "pm.test('Each book has required fields', function () {",
                  "    const json = pm.response.json();",
                  "    json.books.forEach(function(book) {",
                  "        pm.expect(book).to.have.property('id');",
                  "        pm.expect(book).to.have.property('title');",
                  "        pm.expect(book).to.have.property('author');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567803",
          "name": "Create a Book",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Dune\",\n  \"author\": \"Frank Herbert\",\n  \"year\": 1965\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Book is created with correct data', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.book.title).to.eql('Dune');",
                  "    pm.expect(json.book.author).to.eql('Frank Herbert');",
                  "    pm.expect(json.book.year).to.eql(1965);",
                  "    pm.expect(json.book.id).to.be.a('string');",
                  "});",
                  "pm.test('Save book ID for later', function () {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('bookId', json.book.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567804",
          "name": "Get Book by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "header": []
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns the correct book', function () {",
                  "    const json = pm.response.json();",
                  "    const bookId = pm.collectionVariables.get('bookId');",
                  "    pm.expect(json.book.id).to.eql(bookId);",
                  "    pm.expect(json.book.title).to.eql('Dune');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567805",
          "name": "Update a Book",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Dune Messiah\",\n  \"author\": \"Frank Herbert\",\n  \"year\": 1969\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Book is updated', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.book.title).to.eql('Dune Messiah');",
                  "    pm.expect(json.book.year).to.eql(1969);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567806",
          "name": "Delete a Book",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "header": []
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Delete confirmation', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.eql('Book deleted');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567807",
          "name": "Get Deleted Book (404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "header": []
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Error response format', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error.name).to.eql('notFound');",
                  "    pm.expect(json.error.message).to.eql('Book not found');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567808",
          "name": "Create Book - Validation Error",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"author\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Returns validation error', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error.name).to.eql('validationError');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
